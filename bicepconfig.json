{
  "analyzers": {
    "core": {
      "enabled": true,
      "rules": {
        "max-params": {
          "level": "off"
        },
        "no-hardcoded-location": {
          "level": "off"
        },
        "no-unused-params": {
          "level": "warning"
        },
        "no-unused-vars": {
          "level": "warning"
        },
        "use-recent-api-versions": {
          "level": "warning"
        }
      }
    }
  }
}