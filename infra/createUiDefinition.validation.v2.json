{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy Azure Virtual Desktop into an existing virtual network and choose existing subnets from the target subscription."
      }
    },
    "basics": [
      {
        "name": "deploymentPrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Deployment Prefix",
        "defaultValue": "avd1",
        "toolTip": "Naming prefix used for resources other than the host pool.",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9]{1,6}$",
          "validationMessage": "Use 1-6 lowercase letters or digits."
        }
      },
      {
        "name": "environment",
        "type": "Microsoft.Common.DropDown",
        "label": "Environment",
        "defaultValue": "dev",
        "constraints": {
          "required": true,
          "allowedValues": [
            {
              "label": "Development",
              "value": "dev"
            },
            {
              "label": "Test",
              "value": "test"
            },
            {
              "label": "Production",
              "value": "prod"
            }
          ]
        }
      }
    ],
    "steps": [
      {
        "name": "instanceDetails",
        "label": "Instance details",
        "elements": [
          {
            "name": "hostPoolName",
            "type": "Microsoft.Common.TextBox",
            "label": "Host pool name",
            "defaultValue": "[concat('hp-avd-', basics('deploymentPrefix'), '-', basics('environment'))]",
            "constraints": {
              "required": true,
              "regex": "^[A-Za-z0-9-]{3,64}$",
              "validationMessage": "Use 3-64 letters, numbers, or hyphens."
            }
          },
          {
            "name": "sessionHostCount",
            "type": "Microsoft.Common.Slider",
            "label": "Session Host Count",
            "min": 1,
            "max": 10,
            "defaultValue": 1,
            "showStepMarkers": true
          },
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "VM Size",
            "toolTip": "Select the Azure VM size for AVD session hosts. Recommended sizes are pre-filtered for AVD workloads.",
            "recommendedSizes": [
              "Standard_D2ads_v5",
              "Standard_D4ads_v5",
              "Standard_D8ads_v5",
              "Standard_D16ads_v5",
              "Standard_E2ads_v5",
              "Standard_E4ads_v5",
              "Standard_E8ads_v5"
            ],
            "constraints": {
              "allowedSizes": []
            },
            "options": {
              "hideDiskTypeFilter": false
            },
            "osPlatform": "Windows",
            "imageReference": {
              "publisher": "microsoftwindowsdesktop",
              "offer": "office-365",
              "sku": "win11-24h2-avd-m365"
            },
            "count": "[steps('instanceDetails').sessionHostCount]"
          },
          {
            "name": "imageSource",
            "type": "Microsoft.Common.DropDown",
            "label": "Image source",
            "defaultValue": "Marketplace",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Marketplace",
                  "value": "Marketplace"
                },
                {
                  "label": "Azure Compute Gallery",
                  "value": "AzureComputeGallery"
                }
              ]
            }
          },
          {
            "name": "avdCompatibleMarketplaceOs",
            "type": "Microsoft.Common.DropDown",
            "label": "Compatible OS",
            "toolTip": "Curated Azure Virtual Desktop-supported operating systems based on Microsoft Learn prerequisites.",
            "defaultValue": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}",
            "filter": true,
            "visible": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
              "allowedValues": [
                {
                  "label": "Windows 11 Enterprise multi-session + Microsoft 365 Apps",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 11 Enterprise multi-session",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"windows-11\",\"sku\":\"win11-24h2-avd\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 11 Enterprise",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"windows-11\",\"sku\":\"win11-24h2-ent\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise multi-session + Microsoft 365 Apps",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win10-22h2-avd-m365\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise multi-session",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"Windows-10\",\"sku\":\"win10-22h2-avd\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"Windows-10\",\"sku\":\"win10-22h2-ent\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2025",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2025-datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2022",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"windowsserver2022\",\"sku\":\"2022-datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2019",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2019-Datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2016",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2016-Datacenter\",\"version\":\"latest\"}"
                }
              ]
            }
          },
          {
            "name": "galleryPicker",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Azure Compute Gallery",
            "resourceType": "Microsoft.Compute/galleries",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "toolTip": "Select an existing Azure Compute Gallery. Use the subscription selector in the picker to browse across subscriptions. The default view shows galleries in the subscription selected on the Basics tab.",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]"
            },
            "options": {}
          },
          {
            "name": "imageDefinitionsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), not(empty(steps('instanceDetails').galleryPicker.id)))), concat(steps('instanceDetails').galleryPicker.id, '/images?api-version=2022-08-03'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "galleryImageDefinitionName",
            "type": "Microsoft.Common.DropDown",
            "label": "Image definition",
            "placeholder": "Select an image definition...",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "toolTip": "Select the gallery image definition to use for session host VMs.",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "allowedValues": "[map(if(contains(steps('instanceDetails').imageDefinitionsApi, 'value'), steps('instanceDetails').imageDefinitionsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "imageVersionsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), and(not(empty(steps('instanceDetails').galleryPicker.id)), not(empty(steps('instanceDetails').galleryImageDefinitionName))))), concat(steps('instanceDetails').galleryPicker.id, '/images/', steps('instanceDetails').galleryImageDefinitionName, '/versions?api-version=2022-08-03'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "galleryImageVersion",
            "type": "Microsoft.Common.DropDown",
            "label": "Gallery image version",
            "placeholder": "Select a version...",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "toolTip": "Select the image version to deploy. Versions are listed from the selected image definition.",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "allowedValues": "[map(if(contains(steps('instanceDetails').imageVersionsApi, 'value'), steps('instanceDetails').imageVersionsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "sessionHostSecurityType",
            "type": "Microsoft.Common.DropDown",
            "label": "Session host security type",
            "defaultValue": "Auto",
            "toolTip": "Auto uses Trusted Launch for Azure Compute Gallery images and Standard for Marketplace images. Choose Trusted Launch explicitly if your gallery image requires it.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Auto",
                  "value": "Auto"
                },
                {
                  "label": "Standard",
                  "value": "Standard"
                },
                {
                  "label": "Trusted Launch",
                  "value": "TrustedLaunch"
                }
              ]
            }
          },
          {
            "name": "avdMode",
            "type": "Microsoft.Common.DropDown",
            "label": "AVD Mode",
            "defaultValue": "PooledDesktopAndRemoteApp",
            "constraints": {
              "required": false,
              "allowedValues": [
                {
                  "label": "Legacy pooled desktop",
                  "value": ""
                },
                {
                  "label": "Personal Desktop",
                  "value": "PersonalDesktop"
                },
                {
                  "label": "Pooled RemoteApp",
                  "value": "PooledRemoteApp"
                },
                {
                  "label": "Pooled Desktop + RemoteApp",
                  "value": "PooledDesktopAndRemoteApp"
                }
              ]
            }
          },
          {
            "name": "hostPoolTypePooled",
            "type": "Microsoft.Common.DropDown",
            "label": "Host Pool Type",
            "defaultValue": "Pooled",
            "visible": "[not(equals(steps('instanceDetails').avdMode, 'PersonalDesktop'))]",
            "toolTip": "This value follows the selected AVD Mode automatically.",
            "constraints": {
              "required": "[not(equals(steps('instanceDetails').avdMode, 'PersonalDesktop'))]",
              "allowedValues": [
                {
                  "label": "Pooled",
                  "value": "Pooled"
                }
              ]
            }
          },
          {
            "name": "hostPoolTypePersonal",
            "type": "Microsoft.Common.DropDown",
            "label": "Host Pool Type",
            "defaultValue": "Personal",
            "visible": "[equals(steps('instanceDetails').avdMode, 'PersonalDesktop')]",
            "toolTip": "This value follows the selected AVD Mode automatically.",
            "constraints": {
              "required": "[equals(steps('instanceDetails').avdMode, 'PersonalDesktop')]",
              "allowedValues": [
                {
                  "label": "Personal",
                  "value": "Personal"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "networking",
        "label": "Networking",
        "elements": [
          {
            "name": "networkMode",
            "type": "Microsoft.Common.DropDown",
            "label": "Network deployment mode",
            "defaultValue": "Greenfield",
            "toolTip": "Choose whether to create a new spoke VNet and subnets or use an existing VNet and subnets.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Create new spoke VNet and subnets",
                  "value": "Greenfield"
                },
                {
                  "label": "Use existing VNet and subnets",
                  "value": "Brownfield"
                }
              ]
            }
          },
          {
            "name": "newVnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Spoke VNet name",
            "defaultValue": "vnet-avd-spoke",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "Name for the new spoke virtual network to be created for AVD session hosts.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Greenfield')]",
              "regex": "^[a-zA-Z0-9][a-zA-Z0-9_.\\-]{0,62}[a-zA-Z0-9_]$",
              "validationMessage": "2-64 characters. Letters, numbers, underscores, hyphens and periods only."
            }
          },
          {
            "name": "newVnetAddressPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Spoke VNet address space",
            "defaultValue": "10.20.0.0/16",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "CIDR block for the new spoke VNet (e.g. 10.20.0.0/16). Must not overlap with your hub or on-premises networks.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Greenfield')]",
              "regex": "^(10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2\\d|3[01])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3})/(8|9|1[0-9]|2[0-9]|3[0-2])$",
              "validationMessage": "Enter a valid private CIDR such as 10.20.0.0/16."
            }
          },
          {
            "name": "newSessionHostSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Session host subnet name",
            "defaultValue": "snet-avd-sessionhosts",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "Name for the subnet where AVD session host VMs will be deployed.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Greenfield')]",
              "regex": "^[a-zA-Z0-9][a-zA-Z0-9\\-]{0,78}[a-zA-Z0-9]$",
              "validationMessage": "2-80 characters. Letters, numbers and hyphens only."
            }
          },
          {
            "name": "newSessionHostSubnetPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Session host subnet prefix",
            "defaultValue": "10.20.1.0/24",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "CIDR block for the session host subnet. Must be within the spoke VNet address space (e.g. 10.20.1.0/24).",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Greenfield')]",
              "regex": "^(10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2\\d|3[01])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3})/(8|9|1[0-9]|2[0-9]|3[0-2])$",
              "validationMessage": "Enter a valid CIDR such as 10.20.1.0/24."
            }
          },
          {
            "name": "newPrivateEndpointSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Private endpoint subnet name",
            "defaultValue": "snet-avd-privateendpoints",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "Name for the subnet that will host private endpoints (FSLogix storage, monitoring).",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Greenfield')]",
              "regex": "^[a-zA-Z0-9][a-zA-Z0-9\\-]{0,78}[a-zA-Z0-9]$",
              "validationMessage": "2-80 characters. Letters, numbers and hyphens only."
            }
          },
          {
            "name": "newPrivateEndpointSubnetPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Private endpoint subnet prefix",
            "defaultValue": "10.20.2.0/27",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "CIDR block for the private endpoint subnet. /27 (32 addresses) is sufficient (e.g. 10.20.2.0/27).",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Greenfield')]",
              "regex": "^(10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2\\d|3[01])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3})/(8|9|1[0-9]|2[0-9]|3[0-2])$",
              "validationMessage": "Enter a valid CIDR such as 10.20.2.0/27."
            }
          },
          {
            "name": "hubVnet",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Hub virtual network (optional - for VNet peering)",
            "resourceType": "Microsoft.Network/virtualNetworks",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "Select an existing hub VNet to peer the new spoke VNet with. Leave unselected to skip peering.",
            "options": {
              "filter": {
                "subscription": "onBasics"
              }
            }
          },
          {
            "name": "existingVnet",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Existing virtual network",
            "resourceType": "Microsoft.Network/virtualNetworks",
            "visible": "[equals(steps('networking').networkMode, 'Brownfield')]",
            "toolTip": "Select the VNet where AVD session hosts will be deployed.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Brownfield')]"
            },
            "options": {
              "filter": {
                "subscription": "onBasics"
              }
            }
          },
          {
            "name": "subnetsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(equals(steps('networking').networkMode, 'Brownfield'), and(contains(steps('networking').existingVnet, 'id'), not(empty(steps('networking').existingVnet.id)))), concat(steps('networking').existingVnet.id, '/subnets?api-version=2023-09-01'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "sessionHostSubnetName",
            "type": "Microsoft.Common.DropDown",
            "label": "Session host subnet",
            "placeholder": "Select a subnet...",
            "visible": "[equals(steps('networking').networkMode, 'Brownfield')]",
            "toolTip": "Select the subnet where AVD session host VMs will be deployed.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Brownfield')]",
              "allowedValues": "[map(if(contains(steps('networking').subnetsApi, 'value'), steps('networking').subnetsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, ' (', coalesce(item.properties.addressPrefix, ''), ')\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "privateEndpointSubnetName",
            "type": "Microsoft.Common.DropDown",
            "label": "Private endpoint subnet",
            "placeholder": "Select a subnet...",
            "visible": "[equals(steps('networking').networkMode, 'Brownfield')]",
            "toolTip": "Select the subnet for AVD private endpoints (FSLogix storage, monitoring).",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Brownfield')]",
              "allowedValues": "[map(if(contains(steps('networking').subnetsApi, 'value'), steps('networking').subnetsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, ' (', coalesce(item.properties.addressPrefix, ''), ')\",\"value\":\"', item.name, '\"}')))]"
            }
          }
        ]
      },
      {
        "name": "storageMonitoring",
        "label": "Storage and monitoring",
        "elements": [
          {
            "name": "deployFSLogix",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy FSLogix storage",
            "defaultValue": true
          },
          {
            "name": "storageAccountName",
            "type": "Microsoft.Common.TextBox",
            "label": "Storage account name",
            "visible": "[steps('storageMonitoring').deployFSLogix]",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9]{3,24}$",
              "validationMessage": "Use 3-24 lowercase letters or digits."
            }
          },
          {
            "name": "deployFSLogixPrivateEndpoint",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy private endpoint for FSLogix storage (recommended for production)",
            "defaultValue": false,
            "visible": "[steps('storageMonitoring').deployFSLogix]",
            "toolTip": "Deploys a private endpoint in the private endpoint subnet and disables public storage access. When creating a new spoke VNet, the private endpoint subnet is created automatically. When using an existing VNet, provide an existing private endpoint subnet."
          },
          {
            "name": "deployMonitoring",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Log Analytics workspace and enable Monitoring",
            "defaultValue": true,
            "toolTip": "Creates a Log Analytics workspace, enables Azure Virtual Desktop diagnostic settings, deploys Azure Monitor Agent guest telemetry for session hosts, and sends FSLogix storage diagnostics to the workspace."
          }
        ]
      },
      {
        "name": "access",
        "label": "Access and applications",
        "elements": [
          {
            "name": "adminUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Local admin username",
            "defaultValue": "avdadmin",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "adminPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Local admin password",
              "confirmPassword": "Confirm local admin password"
            },
            "constraints": {
              "required": true,
              "regex": "^(?=.{12,})(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^A-Za-z0-9]).*$",
              "validationMessage": "Use at least 12 characters including upper, lower, number, and symbol."
            }
          },
          {
            "name": "desktopAssignments",
            "type": "Microsoft.Common.EditableGrid",
            "ariaLabel": "Desktop app group access assignments",
            "label": "Desktop app group access assignments",
            "visible": "[or(equals(steps('instanceDetails').avdMode, ''), equals(steps('instanceDetails').avdMode, 'PersonalDesktop'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "defaultValue": [],
            "constraints": {
              "width": "Full",
              "rows": {
                "count": {
                  "min": 0,
                  "max": 50
                }
              },
              "columns": [
                {
                  "id": "principalId",
                  "header": "Object ID",
                  "width": "2fr",
                  "element": {
                    "name": "principalId",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
                    "constraints": {
                      "required": true,
                      "regex": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                      "validationMessage": "Must be a valid GUID."
                    }
                  }
                },
                {
                  "id": "principalType",
                  "header": "Type",
                  "width": "1fr",
                  "element": {
                    "name": "principalType",
                    "type": "Microsoft.Common.DropDown",
                    "defaultValue": "User",
                    "constraints": {
                      "required": true,
                      "allowedValues": [
                        {
                          "label": "User",
                          "value": "User"
                        },
                        {
                          "label": "Group",
                          "value": "Group"
                        },
                        {
                          "label": "ServicePrincipal",
                          "value": "ServicePrincipal"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          {
            "name": "remoteAppAssignments",
            "type": "Microsoft.Common.EditableGrid",
            "ariaLabel": "RemoteApp group access assignments",
            "label": "RemoteApp group access assignments",
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "defaultValue": [],
            "constraints": {
              "width": "Full",
              "rows": {
                "count": {
                  "min": 0,
                  "max": 50
                }
              },
              "columns": [
                {
                  "id": "principalId",
                  "header": "Object ID",
                  "width": "2fr",
                  "element": {
                    "name": "principalId",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
                    "constraints": {
                      "required": true,
                      "regex": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                      "validationMessage": "Must be a valid GUID."
                    }
                  }
                },
                {
                  "id": "principalType",
                  "header": "Type",
                  "width": "1fr",
                  "element": {
                    "name": "principalType",
                    "type": "Microsoft.Common.DropDown",
                    "defaultValue": "User",
                    "constraints": {
                      "required": true,
                      "allowedValues": [
                        {
                          "label": "User",
                          "value": "User"
                        },
                        {
                          "label": "Group",
                          "value": "Group"
                        },
                        {
                          "label": "ServicePrincipal",
                          "value": "ServicePrincipal"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          {
            "name": "remoteApps",
            "type": "Microsoft.Common.EditableGrid",
            "ariaLabel": "RemoteApp definitions",
            "label": "RemoteApp definitions",
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Add one row per RemoteApp. Name and executable path are required.",
            "defaultValue": [],
            "constraints": {
              "width": "Full",
              "rows": {
                "count": {
                  "min": 0,
                  "max": 30
                }
              },
              "columns": [
                {
                  "id": "name",
                  "header": "App name",
                  "width": "1fr",
                  "element": {
                    "name": "name",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "Notepad",
                    "constraints": {
                      "required": true,
                      "regex": "^[^\\\\/:*?\"<>|]{1,64}$",
                      "validationMessage": "App name must be 1-64 characters and must not contain \\ / : * ? \" < > |"
                    }
                  }
                },
                {
                  "id": "filePath",
                  "header": "Executable path",
                  "width": "2fr",
                  "element": {
                    "name": "filePath",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "C:\\Windows\\System32\\notepad.exe",
                    "constraints": {
                      "required": true,
                      "regex": "^[A-Za-z]:\\\\.*\\.exe$",
                      "validationMessage": "Must be a full Windows path ending in .exe"
                    }
                  }
                },
                {
                  "id": "friendlyName",
                  "header": "Display name (optional)",
                  "width": "1fr",
                  "element": {
                    "name": "friendlyName",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "Notepad",
                    "constraints": {
                      "required": false
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "deploymentPrefix": "[basics('deploymentPrefix')]",
      "networkMode": "[if(equals(steps('networking').networkMode, 'Greenfield'), 'CreateNewVnet', 'UseExistingVnet')]",
      "existingVnetName": "[if(equals(steps('networking').networkMode, 'Brownfield'), if(contains(steps('networking').existingVnet, 'name'), steps('networking').existingVnet.name, ''), '')]",
      "existingVnetResourceGroupName": "[if(equals(steps('networking').networkMode, 'Brownfield'), if(contains(steps('networking').existingVnet, 'id'), last(take(split(steps('networking').existingVnet.id, '/'), 5)), ''), '')]",
      "newVnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newVnetName, '')]",
      "newVnetAddressPrefix": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newVnetAddressPrefix, '')]",
      "newSessionHostSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newSessionHostSubnetName, '')]",
      "newSessionHostSubnetPrefix": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newSessionHostSubnetPrefix, '')]",
      "newPrivateEndpointSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newPrivateEndpointSubnetName, '')]",
      "newPrivateEndpointSubnetPrefix": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newPrivateEndpointSubnetPrefix, '')]",
      "sessionHostSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newSessionHostSubnetName, steps('networking').sessionHostSubnetName)]",
      "privateEndpointSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), steps('networking').newPrivateEndpointSubnetName, steps('networking').privateEndpointSubnetName)]",
      "hubVnetResourceId": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').hubVnet, 'id'), steps('networking').hubVnet.id, ''), '')]",
      "environment": "[basics('environment')]",
      "sessionHostCount": "[steps('instanceDetails').sessionHostCount]",
      "vmSize": "[steps('instanceDetails').vmSize]",
      "imageSource": "[steps('instanceDetails').imageSource]",
      "sessionHostSecurityType": "[steps('instanceDetails').sessionHostSecurityType]",
      "marketplaceImagePublisher": "[parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).publisher]",
      "marketplaceImageOffer": "[parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).offer]",
      "marketplaceImageSku": "[parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).sku]",
      "marketplaceImageVersion": "[parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).version]",
      "galleryImageSubscriptionId": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), not(empty(steps('instanceDetails').galleryPicker.id)))), last(take(split(steps('instanceDetails').galleryPicker.id, '/'), 3)), subscription().subscriptionId)]",
      "galleryImageResourceGroupName": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), not(empty(steps('instanceDetails').galleryPicker.id)))), last(take(split(steps('instanceDetails').galleryPicker.id, '/'), 5)), '')]",
      "galleryName": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), contains(steps('instanceDetails').galleryPicker, 'name')), steps('instanceDetails').galleryPicker.name, '')]",
      "galleryImageDefinitionName": "[steps('instanceDetails').galleryImageDefinitionName]",
      "galleryImageVersion": "[steps('instanceDetails').galleryImageVersion]",
      "avdMode": "[steps('instanceDetails').avdMode]",
      "hostPoolType": "[if(equals(steps('instanceDetails').avdMode, 'PersonalDesktop'), steps('instanceDetails').hostPoolTypePersonal, steps('instanceDetails').hostPoolTypePooled)]",
      "hostPoolName": "[steps('instanceDetails').hostPoolName]",
      "adminUsername": "[steps('access').adminUsername]",
      "adminPassword": "[steps('access').adminPassword]",
      "deployFSLogix": "[steps('storageMonitoring').deployFSLogix]",
      "storageAccountName": "[steps('storageMonitoring').storageAccountName]",
      "deployFSLogixPrivateEndpoint": "[steps('storageMonitoring').deployFSLogixPrivateEndpoint]",
      "deployMonitoring": "[steps('storageMonitoring').deployMonitoring]",
      "avdUserObjectIds": "",
      "desktopAccessAssignments": "[steps('access').desktopAssignments]",
      "remoteAppAccessAssignments": "[steps('access').remoteAppAssignments]",
      "remoteApps": "[steps('access').remoteApps]"
    }
  }
}
