{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Configure or update a scaling plan for an existing pooled Azure Virtual Desktop host pool without reopening the broader day-2 operations wizard.",
        "resourceGroup": {
          "allowExisting": true
        },
        "subscription": {
          "resourceProviders": [
            "Microsoft.Compute",
            "Microsoft.DesktopVirtualization",
            "Microsoft.Insights",
            "Microsoft.Network",
            "Microsoft.OperationalInsights",
            "Microsoft.Storage"
          ]
        },
        "location": {
          "resourceTypes": [
            "Microsoft.DesktopVirtualization/hostPools"
          ]
        }
      }
    },
    "basics": [
      {
        "name": "deploymentPrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Deployment Prefix",
        "defaultValue": "avd1",
        "toolTip": "Naming prefix used for deployment metadata and shared resources.",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9]{1,6}$",
          "validationMessage": "Use 1-6 lowercase letters or digits."
        }
      },
      {
        "name": "environment",
        "type": "Microsoft.Common.DropDown",
        "label": "Environment",
        "defaultValue": "dev",
        "constraints": {
          "required": true,
          "allowedValues": [
            {
              "label": "Development",
              "value": "dev"
            },
            {
              "label": "Test",
              "value": "test"
            },
            {
              "label": "Production",
              "value": "prod"
            }
          ]
        }
      }
    ],
    "steps": [
      {
        "name": "brownfieldTarget",
        "label": "Existing AVD target",
        "elements": [
          {
            "name": "selectedHostPool",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Existing host pool",
            "resourceType": "Microsoft.DesktopVirtualization/hostPools",
            "toolTip": "Select the pooled host pool that should receive the scaling plan attachment.",
            "constraints": {
              "required": true
            },
            "options": {
              "filter": {
                "subscription": "onBasics"
              }
            }
          },
          {
            "name": "selectedHostPoolApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat(steps('brownfieldTarget').selectedHostPool.id, '?api-version=2025-10-10'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "scalingPlansApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), '/providers/Microsoft.DesktopVirtualization/scalingPlans?api-version=2025-10-10'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "appGroupsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), '/providers/Microsoft.DesktopVirtualization/applicationGroups?api-version=2024-04-03'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "workspacesApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), '/providers/Microsoft.DesktopVirtualization/workspaces?api-version=2024-04-03'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "hostPoolDiagnosticsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat(steps('brownfieldTarget').selectedHostPool.id, '/providers/Microsoft.Insights/diagnosticSettings?api-version=2021-05-01-preview'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "sessionHostsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat(steps('brownfieldTarget').selectedHostPool.id, '/sessionHosts?api-version=2024-04-03'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "resourceGroupResourcesApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), '/resources?api-version=2021-04-01'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "resourceGroupRoleAssignmentsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(contains(steps('brownfieldTarget').selectedHostPool, 'id'), not(empty(steps('brownfieldTarget').selectedHostPool.id))), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), '/providers/Microsoft.Authorization/roleAssignments?api-version=2022-04-01'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "hostPoolInspectionSummary",
            "type": "Microsoft.Common.TextBlock",
            "options": {
              "text": "[concat('Selected host pool: ', if(contains(steps('brownfieldTarget').selectedHostPool, 'name'), steps('brownfieldTarget').selectedHostPool.name, 'None'), '. Type: ', if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), contains(steps('brownfieldTarget').selectedHostPoolApi.properties, 'hostPoolType')), steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Unknown'), '.')]"
            }
          },
          {
            "name": "scalingPlanInspectionSummary",
            "type": "Microsoft.Common.TextBlock",
            "options": {
              "text": "[concat('Scaling plans discovered in the target resource group: ', string(length(if(contains(steps('brownfieldTarget').scalingPlansApi, 'value'), steps('brownfieldTarget').scalingPlansApi.value, parse('[]')))), '. This wizard will only create or update the named scaling plan for the selected pooled host pool.')]"
            }
            },
            {
              "name": "scalingPlanValidationMessage",
              "type": "Microsoft.Common.TextBlock",
              "visible": "[and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), not(equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')))]",
              "options": {
                "text": "Scaling plan management is currently supported only for pooled host pools. Select a pooled host pool to continue."
              }
          }
        ]
      },
      {
        "name": "scalingPlanSettings",
        "label": "Scaling plan",
        "visible": "[and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled'))]",
        "elements": [
          {
            "name": "scalingPlanName",
            "type": "Microsoft.Common.TextBox",
            "label": "Scaling plan name",
            "defaultValue": "sp-avd-scaling",
            "constraints": {
              "required": true,
              "regex": "^[A-Za-z0-9@._ -]{3,64}$",
              "validationMessage": "Use 3-64 letters, numbers, spaces, periods, underscores, or hyphens."
            }
          },
          {
            "name": "scalingPlanFriendlyName",
            "type": "Microsoft.Common.TextBox",
            "label": "Friendly name",
            "defaultValue": "AVD Scaling Plan",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "scalingPlanDescription",
            "type": "Microsoft.Common.TextBox",
            "label": "Description",
            "defaultValue": "Brownfield scaling plan managed by the dedicated AVD scaling wizard.",
            "multiLine": true,
            "constraints": {
              "required": false
            }
          },
          {
            "name": "scalingPlanTimeZone",
            "type": "Microsoft.Common.TextBox",
            "label": "Time zone",
            "defaultValue": "UTC",
            "toolTip": "Use a Windows time zone identifier such as UTC, GMT Standard Time, or Pacific Standard Time.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "scalingPlanExclusionTag",
            "type": "Microsoft.Common.TextBox",
            "label": "Exclusion tag (optional)",
            "defaultValue": "",
            "toolTip": "Any session host carrying this tag is excluded from scaling actions.",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "weekdayRampUpStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekday ramp-up start",
            "defaultValue": "06:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekdayPeakStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekday peak start",
            "defaultValue": "09:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekdayRampDownStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekday ramp-down start",
            "defaultValue": "17:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekdayOffPeakStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekday off-peak start",
            "defaultValue": "20:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekendRampUpStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekend ramp-up start",
            "defaultValue": "08:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekendPeakStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekend peak start",
            "defaultValue": "10:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekendRampDownStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekend ramp-down start",
            "defaultValue": "15:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "weekendOffPeakStartTime",
            "type": "Microsoft.Common.TextBox",
            "label": "Weekend off-peak start",
            "defaultValue": "18:00",
            "constraints": {
              "required": true,
              "regex": "^([01]\\d|2[0-3]):[0-5]\\d$",
              "validationMessage": "Use 24-hour HH:mm format."
            }
          },
          {
            "name": "rampUpLoadBalancingAlgorithm",
            "type": "Microsoft.Common.DropDown",
            "label": "Ramp-up load balancing",
            "defaultValue": "BreadthFirst",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Breadth-first",
                  "value": "BreadthFirst"
                },
                {
                  "label": "Depth-first",
                  "value": "DepthFirst"
                }
              ]
            }
          },
          {
            "name": "peakLoadBalancingAlgorithm",
            "type": "Microsoft.Common.DropDown",
            "label": "Peak load balancing",
            "defaultValue": "BreadthFirst",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Breadth-first",
                  "value": "BreadthFirst"
                },
                {
                  "label": "Depth-first",
                  "value": "DepthFirst"
                }
              ]
            }
          },
          {
            "name": "rampDownLoadBalancingAlgorithm",
            "type": "Microsoft.Common.DropDown",
            "label": "Ramp-down load balancing",
            "defaultValue": "DepthFirst",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Breadth-first",
                  "value": "BreadthFirst"
                },
                {
                  "label": "Depth-first",
                  "value": "DepthFirst"
                }
              ]
            }
          },
          {
            "name": "offPeakLoadBalancingAlgorithm",
            "type": "Microsoft.Common.DropDown",
            "label": "Off-peak load balancing",
            "defaultValue": "DepthFirst",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Breadth-first",
                  "value": "BreadthFirst"
                },
                {
                  "label": "Depth-first",
                  "value": "DepthFirst"
                }
              ]
            }
          },
          {
            "name": "minimumHostsPct",
            "type": "Microsoft.Common.Slider",
            "label": "Minimum running hosts (%)",
            "min": 0,
            "max": 100,
            "defaultValue": 20,
            "showStepMarkers": true
          },
          {
            "name": "capacityThresholdPct",
            "type": "Microsoft.Common.Slider",
            "label": "Capacity threshold (%)",
            "min": 1,
            "max": 100,
            "defaultValue": 75,
            "showStepMarkers": true
          },
          {
            "name": "rampDownWaitTimeMinutes",
            "type": "Microsoft.Common.Slider",
            "label": "Ramp-down wait time (minutes)",
            "min": 0,
            "max": 120,
            "defaultValue": 30,
            "showStepMarkers": true
          },
          {
            "name": "rampDownStopHostsWhen",
            "type": "Microsoft.Common.DropDown",
            "label": "Stop hosts when",
            "defaultValue": "ZeroSessions",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Zero sessions",
                  "value": "ZeroSessions"
                },
                {
                  "label": "Zero active sessions",
                  "value": "ZeroActiveSessions"
                }
              ]
            }
          },
          {
            "name": "rampDownForceLogoffUsers",
            "type": "Microsoft.Common.CheckBox",
            "label": "Force logoff during ramp-down",
            "defaultValue": false
          },
          {
            "name": "rampDownNotificationMessage",
            "type": "Microsoft.Common.TextBox",
            "label": "Ramp-down notification message",
            "defaultValue": "This session host will be stopped by the Azure Virtual Desktop scaling plan.",
            "multiLine": true,
            "constraints": {
              "required": false
            }
          }
        ]
      },
      {
        "name": "review",
        "label": "Review",
        "visible": "[and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled'))]",
        "elements": [
          {
            "name": "reviewTargetSummary",
            "type": "Microsoft.Common.TextBlock",
            "options": {
              "text": "[concat('Target host pool: ', if(contains(steps('brownfieldTarget').selectedHostPool, 'name'), steps('brownfieldTarget').selectedHostPool.name, ''), ' in resource group ', if(contains(steps('brownfieldTarget').selectedHostPool, 'id'), last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), ''), '.')]"
            }
          },
          {
            "name": "reviewActionSummary",
            "type": "Microsoft.Common.TextBlock",
            "options": {
              "text": "[concat('Requested action: configure scaling plan ', steps('scalingPlanSettings').scalingPlanName, ' with time zone ', steps('scalingPlanSettings').scalingPlanTimeZone, '. Session hosts are not recreated by this workflow.')]"
            }
          },
          {
            "name": "reviewScheduleSummary",
            "type": "Microsoft.Common.TextBlock",
            "options": {
              "text": "[concat('Weekday schedule: ', steps('scalingPlanSettings').weekdayRampUpStartTime, ' ramp-up, ', steps('scalingPlanSettings').weekdayPeakStartTime, ' peak, ', steps('scalingPlanSettings').weekdayRampDownStartTime, ' ramp-down, ', steps('scalingPlanSettings').weekdayOffPeakStartTime, ' off-peak. Weekend schedule: ', steps('scalingPlanSettings').weekendRampUpStartTime, ', ', steps('scalingPlanSettings').weekendPeakStartTime, ', ', steps('scalingPlanSettings').weekendRampDownStartTime, ', ', steps('scalingPlanSettings').weekendOffPeakStartTime, '.')]"
            }
          }
        ]
      }
    ],
    "outputs": {
      "applicationResourceName": "[if(contains(steps('brownfieldTarget').selectedHostPool, 'name'), steps('brownfieldTarget').selectedHostPool.name, 'avd-scaling-action')]",
      "location": "[if(contains(steps('brownfieldTarget').selectedHostPool, 'location'), steps('brownfieldTarget').selectedHostPool.location, location())]",
      "deploymentPrefix": "[basics('deploymentPrefix')]",
      "deploymentScenario": "Day2Operations",
      "expandOperation": "",
      "day2Operation": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), 'ConfigureScalingPlan', '')]",
      "environment": "[basics('environment')]",
      "networkMode": "UseExistingVnet",
      "sessionHostCount": 1,
      "vmSize": "Standard_D2ads_v5",
      "imageSource": "Marketplace",
      "sessionHostSecurityType": "Standard",
      "hostPoolType": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), contains(steps('brownfieldTarget').selectedHostPoolApi.properties, 'hostPoolType')), steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')]",
      "hostPoolName": "[if(contains(steps('brownfieldTarget').selectedHostPool, 'name'), steps('brownfieldTarget').selectedHostPool.name, '')]",
      "existingHostPoolResourceGroupName": "[if(contains(steps('brownfieldTarget').selectedHostPool, 'id'), last(take(split(steps('brownfieldTarget').selectedHostPool.id, '/'), 5)), '')]",
      "existingWorkspaceNames": "[map(filter(if(contains(steps('brownfieldTarget').workspacesApi, 'value'), steps('brownfieldTarget').workspacesApi.value, parse('[]')), (workspace) => greater(length(filter(if(contains(steps('brownfieldTarget').appGroupsApi, 'value'), steps('brownfieldTarget').appGroupsApi.value, parse('[]')), (appGroup) => and(equals(appGroup.properties.hostPoolArmPath, steps('brownfieldTarget').selectedHostPool.id), contains(string(workspace.properties.applicationGroupReferences), appGroup.id)))), 0)), (workspace) => workspace.name)]",
      "relatedApplicationGroupNames": "[map(filter(if(contains(steps('brownfieldTarget').appGroupsApi, 'value'), steps('brownfieldTarget').appGroupsApi.value, parse('[]')), (appGroup) => equals(appGroup.properties.hostPoolArmPath, steps('brownfieldTarget').selectedHostPool.id)), (appGroup) => appGroup.name)]",
      "relatedDesktopApplicationGroupNames": "[map(filter(if(contains(steps('brownfieldTarget').appGroupsApi, 'value'), steps('brownfieldTarget').appGroupsApi.value, parse('[]')), (appGroup) => and(equals(appGroup.properties.hostPoolArmPath, steps('brownfieldTarget').selectedHostPool.id), equals(appGroup.properties.applicationGroupType, 'Desktop'))), (appGroup) => appGroup.name)]",
      "relatedRemoteAppApplicationGroupNames": "[map(filter(if(contains(steps('brownfieldTarget').appGroupsApi, 'value'), steps('brownfieldTarget').appGroupsApi.value, parse('[]')), (appGroup) => and(equals(appGroup.properties.hostPoolArmPath, steps('brownfieldTarget').selectedHostPool.id), equals(appGroup.properties.applicationGroupType, 'RemoteApp'))), (appGroup) => appGroup.name)]",
      "brownfieldDetectedLoadBalancerType": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), contains(steps('brownfieldTarget').selectedHostPoolApi.properties, 'loadBalancerType')), steps('brownfieldTarget').selectedHostPoolApi.properties.loadBalancerType, '')]",
      "brownfieldDetectedPreferredAppGroupType": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), contains(steps('brownfieldTarget').selectedHostPoolApi.properties, 'preferredAppGroupType')), steps('brownfieldTarget').selectedHostPoolApi.properties.preferredAppGroupType, '')]",
      "brownfieldDetectedAuthenticationType": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), contains(steps('brownfieldTarget').selectedHostPoolApi.properties, 'customRdpProperty')), if(contains(string(steps('brownfieldTarget').selectedHostPoolApi.properties.customRdpProperty), 'targetisaadjoined:i:1'), 'EntraID', 'HybridJoin'), 'Unknown')]",
      "brownfieldDetectedHostPoolDiagnosticSettingNames": "[map(if(contains(steps('brownfieldTarget').hostPoolDiagnosticsApi, 'value'), steps('brownfieldTarget').hostPoolDiagnosticsApi.value, parse('[]')), (setting) => setting.name)]",
      "brownfieldDetectedWorkspacesWithDiagnostics": "[map(filter(if(contains(steps('brownfieldTarget').workspacesApi, 'value'), steps('brownfieldTarget').workspacesApi.value, parse('[]')), (workspace) => greater(length(filter(if(contains(steps('brownfieldTarget').resourceGroupResourcesApi, 'value'), steps('brownfieldTarget').resourceGroupResourcesApi.value, parse('[]')), (resource) => contains(resource.id, concat(workspace.id, '/providers/Microsoft.Insights/diagnosticSettings/')))), 0)), (workspace) => workspace.name)]",
      "brownfieldDetectedApplicationGroupsWithDiagnostics": "[map(filter(if(contains(steps('brownfieldTarget').appGroupsApi, 'value'), steps('brownfieldTarget').appGroupsApi.value, parse('[]')), (appGroup) => and(equals(appGroup.properties.hostPoolArmPath, steps('brownfieldTarget').selectedHostPool.id), greater(length(filter(if(contains(steps('brownfieldTarget').resourceGroupResourcesApi, 'value'), steps('brownfieldTarget').resourceGroupResourcesApi.value, parse('[]')), (resource) => contains(resource.id, concat(appGroup.id, '/providers/Microsoft.Insights/diagnosticSettings/')))), 0))), (appGroup) => appGroup.name)]",
      "brownfieldDetectedScalingPlanNames": "[map(filter(if(contains(steps('brownfieldTarget').scalingPlansApi, 'value'), steps('brownfieldTarget').scalingPlansApi.value, parse('[]')), (plan) => contains(string(plan.properties.hostPoolReferences), steps('brownfieldTarget').selectedHostPool.id)), (plan) => plan.name)]",
      "brownfieldDetectedSessionHostVmNames": "[map(if(contains(steps('brownfieldTarget').sessionHostsApi, 'value'), steps('brownfieldTarget').sessionHostsApi.value, parse('[]')), (sessionHost) => first(split(last(split(sessionHost.name, '/')), '.')))]",
      "adminUsername": "",
      "adminPassword": "",
      "deployFSLogix": false,
      "storageAccountName": "",
      "deployFSLogixPrivateEndpoint": false,
      "deployMonitoring": false,
      "scalingPlanName": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').scalingPlanName, '')]",
      "scalingPlanFriendlyName": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').scalingPlanFriendlyName, '')]",
      "scalingPlanDescription": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').scalingPlanDescription, '')]",
      "scalingPlanTimeZone": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').scalingPlanTimeZone, 'UTC')]",
      "scalingPlanExclusionTag": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').scalingPlanExclusionTag, '')]",
      "weekdayRampUpStartTime": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').weekdayRampUpStartTime, '06:00')]",
      "weekdayPeakStartTime": "[if(and(contains(steps('brownfieldTarget').selectedHostPoolApi, 'properties'), equals(steps('brownfieldTarget').selectedHostPoolApi.properties.hostPoolType, 'Pooled')), steps('scalingPlanSettings').weekdayPeakStartTime, '09:00')]",
